<Window x:Class="SideBarTaskSwitcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SideBarTaskSwitcher"
        mc:Ignorable="d"
        Title="SideBar Task Switcher" 
        Height="Auto" 
        Width="280"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Topmost="False"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="#CCF5F5F5"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#33000000" Padding="10">
            <Grid>
                <TextBlock Text="Tasks" FontWeight="Bold" VerticalAlignment="Center" Foreground="#333"/>
                <Button Content="✕" Width="24" Height="24" HorizontalAlignment="Right" 
                        Click="CloseButton_Click" Background="Transparent" BorderThickness="0"
                        Foreground="#333" FontWeight="Bold" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Window List -->
        <ListBox x:Name="WindowsList" Background="Transparent" BorderThickness="0" 
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 SelectionChanged="WindowsList_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="5" Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Image Source="{Binding IconSource}" Width="24" Height="24" Stretch="Uniform" />
                        <TextBlock Grid.Column="1" Text="{Binding Title}" VerticalAlignment="Center" 
                                   Margin="10,0,0,0" TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="5"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>
    </DockPanel>
</Window>
