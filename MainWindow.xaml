<Window x:Class="YomogiTaskBar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:YomogiTaskBar"
        mc:Ignorable="d"
        Title="YomogiTaskBar" 
        Height="Auto" 
        Width="280"
        WindowStyle="None" 
        AllowsTransparency="False" 
        Topmost="False"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}"
        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0"
        SourceInitialized="Window_SourceInitialized"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave">
    <Window.Resources>
        <FontFamily x:Key="IconFont">Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol</FontFamily>

        <!-- General Button Style -->
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#007ACC"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ItemHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Modern ScrollBar Style -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="Transparent"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBorder" CornerRadius="3" Background="{DynamicResource SecondaryTextBrush}" Opacity="0.5" Margin="0,2"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Opacity" Value="0.8"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Opacity" Value="1.0"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>
    <Grid>
        <!-- Resize Handle -->
        <Thumb x:Name="ResizeThumb" HorizontalAlignment="Left" Width="8" Cursor="SizeWE" 
               DragStarted="Thumb_DragStarted" DragDelta="Thumb_DragDelta" DragCompleted="Thumb_DragCompleted" Panel.ZIndex="1"
               AutomationProperties.Name="リサイズハンドル" AutomationProperties.HelpText="ドラッグしてウィンドウ幅を調整">
            <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="HandleBorder" Background="Transparent" Width="8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#20007ACC"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>
        
        <DockPanel x:Name="MainDockPanel">
            <!-- Header (Title Bar) -->
            <Border x:Name="HeaderBorder" DockPanel.Dock="Top" Background="{DynamicResource HeaderBackgroundBrush}" Padding="16,10,10,10" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    AutomationProperties.Name="タイトルバー" AutomationProperties.HelpText="ウィンドウのドラッグ移動とアプリケーション操作">
                <Grid>
                    <TextBlock Text="YomogiTaskBar" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}"
                               AutomationProperties.Name="YomogiTaskBar" AutomationProperties.HelpText="アプリケーションタイトル"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="PinButton" Focusable="False" Content="📌" Width="32" Height="32" FontSize="14"
                                Click="PinButton_Click" Background="Transparent" BorderThickness="0"
                                Foreground="{DynamicResource PrimaryTextBrush}" Cursor="Hand" ToolTip="ピン留めを切り替え"
                                AutomationProperties.Name="ピン留めボタン" AutomationProperties.HelpText="ウィンドウを画面に固定または解除します"/>
                        <Button x:Name="SettingsButton" Focusable="False" Content="⚙️" Width="32" Height="32" FontSize="14"
                                Click="SettingsButton_Click" Background="Transparent" BorderThickness="0" Margin="4,0"
                                Foreground="{DynamicResource PrimaryTextBrush}" Cursor="Hand" ToolTip="設定"
                                AutomationProperties.Name="設定ボタン" AutomationProperties.HelpText="アプリケーション設定を開きます"/>
                        
                        <!-- Custom Close Button with Red Hover -->
                        <Button Focusable="False" Content="✕" Width="32" Height="32" FontSize="12"
                                Click="CloseButton_Click" Background="Transparent" BorderThickness="0"
                                Foreground="{DynamicResource PrimaryTextBrush}" Cursor="Hand"
                                AutomationProperties.Name="閉じるボタン" AutomationProperties.HelpText="アプリケーションを終了します">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#E81123"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Virtual Desktop Footer -->
            <Border x:Name="FooterBorder" DockPanel.Dock="Bottom" VerticalAlignment="Bottom" Background="{DynamicResource HeaderBackgroundBrush}" Padding="16,10,10,10" 
                    Cursor="Hand" MouseLeftButtonDown="DesktopFooter_Click" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                    AutomationProperties.Name="仮想デスクトップフッター" AutomationProperties.HelpText="現在の仮想デスクトップ情報と切り替えメニュー">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock x:Name="CurrentDesktopText" Text="Desktop 1" Foreground="{DynamicResource PrimaryTextBrush}" FontWeight="SemiBold" FontSize="12"
                               AutomationProperties.Name="現在のデスクトップ" AutomationProperties.HelpText="現在アクティブな仮想デスクトップ名"/>
                    <TextBlock Text="&#xE70D;" FontFamily="{StaticResource IconFont}" FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" Margin="6,0,0,0"
                               AutomationProperties.Name="メニュー展開ボタン" AutomationProperties.HelpText="仮想デスクトップ切り替えメニューを展開"/>
                </StackPanel>
                <Border.ContextMenu>
                    <ContextMenu x:Name="DesktopContextMenu">
                        <!-- Items populated dynamically -->
                    </ContextMenu>
                </Border.ContextMenu>
            </Border>

            <!-- Window List -->
            <ListBox x:Name="WindowsList" Margin="6,0,0,0" Background="Transparent" BorderThickness="0" 
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     MouseLeftButtonUp="WindowsList_MouseLeftButtonUp"
                     KeyDown="WindowsList_KeyDown"
                     AutomationProperties.Name="ウィンドウリスト" AutomationProperties.HelpText="実行中のアプリケーション一覧。選択してウィンドウを切り替えます">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="5,2" Background="Transparent" x:Name="RootGrid">
                            <Grid x:Name="ContentGrid">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0">
                                    <Image Source="{Binding IconSource}" Width="24" Height="24" Stretch="Uniform" 
                                           AutomationProperties.Name="{Binding Title}" AutomationProperties.HelpText="アプリケーションアイコン"/>
                                    <Border x:Name="MonitorBadge" Background="#AA000000" CornerRadius="7" Width="14" Height="14" 
                                            HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-2,-2"
                                            AutomationProperties.Name="モニターバッジ" AutomationProperties.HelpText="ウィンドウが表示されているモニター番号">
                                        <TextBlock Text="{Binding MonitorIndex}" Foreground="White" FontSize="9" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                    </Border>
                                </Grid>

                                <!-- Title + Floating button overlay (same column) -->
                                <Grid Grid.Column="1">
                                    <TextBlock Text="{Binding Title}" VerticalAlignment="Center" FontSize="12"
                                               Margin="10,0,0,0" TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               AutomationProperties.Name="{Binding Title}" AutomationProperties.HelpText="ウィンドウタイトル"/>

                                    <!-- Hover buttons overlay: gradient + buttons appear on top of title -->
                                    <Border x:Name="HoverButtonOverlay" HorizontalAlignment="Right" VerticalAlignment="Stretch"
                                            Opacity="0" Padding="30,0,0,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="Transparent" Offset="0"/>
                                                <GradientStop Color="{DynamicResource ItemHoverColor}" Offset="0.5"/>
                                                <GradientStop Color="{DynamicResource ItemHoverColor}" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
                                            <!-- Minimize/Restore Button -->
                                            <Button x:Name="ItemMinRestoreBtn" Content="─" Width="20" Height="20" Margin="0,0,4,0"
                                                    Background="#22000000" BorderThickness="0"
                                                    Foreground="{DynamicResource PrimaryTextBrush}" FontSize="10" FontWeight="Bold"
                                                    Cursor="Hand" Click="MinimizeRestoreItemButton_Click" ToolTip="最小化"
                                                    AutomationProperties.Name="最小化/復元ボタン">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="10">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource BorderBrush}"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>

                                            <!-- Close Button -->
                                            <Button x:Name="ItemCloseBtn" Content="✕" Width="20" Height="20"
                                                    Background="#22000000" BorderThickness="0"
                                                    Foreground="{DynamicResource PrimaryTextBrush}" FontSize="10" FontWeight="Bold"
                                                    Cursor="Hand" Click="CloseItemButton_Click" ToolTip="このウィンドウを閉じる"
                                                    AutomationProperties.Name="ウィンドウを閉じる"
                                                    AutomationProperties.HelpText="{Binding Title, StringFormat='{}{0} を閉じます'}">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="10">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Border" Property="Background" Value="#E81123"/>
                                                                            <Setter Property="Foreground" Value="White"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                            <!-- Separator line -->
                            <Border x:Name="SeparatorBorder" Height="1" Background="{DynamicResource ItemSeparatorBrush}" Margin="10,5" Visibility="Collapsed"/>
                        </Grid>
                        <DataTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverButtonOverlay" Property="Opacity" Value="1"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                                <Setter TargetName="ContentGrid" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="SeparatorBorder" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="MonitorBadge" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsMinimized}" Value="True">
                                <Setter TargetName="ContentGrid" Property="Opacity" Value="0.5"/>
                                <Setter TargetName="ItemMinRestoreBtn" Property="Content" Value="&#x2191;"/>
                                <Setter TargetName="ItemMinRestoreBtn" Property="ToolTip" Value="元に戻す"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding MonitorIndex}" Value="0">
                                <Setter TargetName="MonitorBadge" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding MonitorIndex}" Value="1">
                                <Setter TargetName="MonitorBadge" Property="Background" Value="#0078D7"/> <!-- Windows Blue -->
                            </DataTrigger>
                            <DataTrigger Binding="{Binding MonitorIndex}" Value="2">
                                <Setter TargetName="MonitorBadge" Property="Background" Value="#107C10"/> <!-- Windows Green -->
                            </DataTrigger>
                            <DataTrigger Binding="{Binding MonitorIndex}" Value="3">
                                <Setter TargetName="MonitorBadge" Property="Background" Value="#D83B01"/> <!-- Windows Orange/Red -->
                            </DataTrigger>
                            <DataTrigger Binding="{Binding MonitorIndex}" Value="4">
                                <Setter TargetName="MonitorBadge" Property="Background" Value="#5C2D91"/> <!-- Windows Purple -->
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="5"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <!-- Use an overlay Border for smooth hover animation -->
                                    <Grid>
                                        <Border x:Name="HoverOverlay" Background="{DynamicResource ItemHoverBrush}" Opacity="0" CornerRadius="6" Margin="2,0"/>
                                        <Border x:Name="Border" Background="Transparent" BorderThickness="0" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Stretch"/>
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="HoverOverlay" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="HoverOverlay" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="HoverOverlay" Property="Opacity" Value="1"/>
                                            <Setter TargetName="HoverOverlay" Property="Background" Value="{DynamicResource ItemHoverBrush}"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter TargetName="HoverOverlay" Property="Opacity" Value="0.5"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                            <Setter Property="Cursor" Value="Arrow"/>
                                            <Setter TargetName="HoverOverlay" Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </DockPanel>
    </Grid>
</Window>
