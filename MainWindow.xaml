<Window x:Class="SideBarTaskSwitcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SideBarTaskSwitcher"
        mc:Ignorable="d"
        Title="SideBar Task Switcher" 
        Height="Auto" 
        Width="280"
        WindowStyle="None" 
        AllowsTransparency="False" 
        Topmost="False"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="#F5F5F5"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave">
    <Grid>
        <!-- Resize Handle -->
        <Thumb x:Name="ResizeThumb" HorizontalAlignment="Left" Width="6" Cursor="SizeWE" 
               DragStarted="Thumb_DragStarted" DragDelta="Thumb_DragDelta" DragCompleted="Thumb_DragCompleted" Panel.ZIndex="1">
            <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                    <Border Background="Transparent"/>
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>
        
        <DockPanel x:Name="MainDockPanel">
            <!-- Header (Title Bar) -->
        <Border x:Name="HeaderBorder" DockPanel.Dock="Top" Background="#33000000" Padding="16,10,10,10" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <TextBlock Text="Tasks" FontWeight="Bold" VerticalAlignment="Center" Foreground="#333"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="PinButton" Content="📌" Width="24" Height="24" 
                            Click="PinButton_Click" Background="Transparent" BorderThickness="0"
                            Foreground="#333" FontWeight="Bold" Cursor="Hand" ToolTip="ピン留めを切り替え"/>
                    <Button Content="✕" Width="24" Height="24" 
                            Click="CloseButton_Click" Background="Transparent" BorderThickness="0"
                            Foreground="#333" FontWeight="Bold" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Virtual Desktop Footer -->
        <Border x:Name="FooterBorder" DockPanel.Dock="Bottom" VerticalAlignment="Bottom" Background="#11000000" Padding="16,10,10,10" 
                Cursor="Hand" MouseLeftButtonDown="DesktopFooter_Click" BorderBrush="#22000000" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock x:Name="CurrentDesktopText" Text="Desktop 1" Foreground="#333" FontWeight="SemiBold"/>
                <TextBlock Text=" ▾" Foreground="#666"/>
            </StackPanel>
            <Border.ContextMenu>
                <ContextMenu x:Name="DesktopContextMenu">
                    <!-- Items populated dynamically -->
                </ContextMenu>
            </Border.ContextMenu>
        </Border>

        <!-- Window List -->
        <ListBox x:Name="WindowsList" Margin="6,0,0,0" Background="Transparent" BorderThickness="0" 
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 SelectionChanged="WindowsList_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="5" Background="Transparent">
                        <Grid x:Name="ContentGrid">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Image Source="{Binding IconSource}" Width="24" Height="24" Stretch="Uniform" />
                                <Border x:Name="MonitorBadge" Background="#AA000000" CornerRadius="7" Width="14" Height="14" 
                                        HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-2,-2">
                                    <TextBlock Text="{Binding MonitorIndex}" Foreground="White" FontSize="9" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                            <TextBlock Grid.Column="1" Text="{Binding Title}" VerticalAlignment="Center" 
                                       Margin="10,0,0,0" TextTrimming="CharacterEllipsis"/>
                            <Button Grid.Column="2" Content="✕" Width="20" Height="20" Margin="5,0,0,0"
                                    Background="Transparent" BorderThickness="0" Foreground="#A000"
                                    FontWeight="Bold" Cursor="Hand" Click="CloseItemButton_Click"
                                    ToolTip="このウィンドウを閉じる"/>
                        </Grid>
                        <!-- Separator line -->
                        <Border x:Name="SeparatorBorder" Height="1" Background="#A0A0A0" Margin="10,5" Visibility="Collapsed"/>
                    </Grid>
                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                            <Setter TargetName="ContentGrid" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="SeparatorBorder" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="MonitorBadge" Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsMinimized}" Value="True">
                            <!-- Make minimized windows look slightly faded -->
                            <Setter TargetName="ContentGrid" Property="Opacity" Value="0.5"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding MonitorIndex}" Value="0">
                            <Setter TargetName="MonitorBadge" Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding MonitorIndex}" Value="1">
                            <Setter TargetName="MonitorBadge" Property="Background" Value="#0078D7"/> <!-- Windows Blue -->
                        </DataTrigger>
                        <DataTrigger Binding="{Binding MonitorIndex}" Value="2">
                            <Setter TargetName="MonitorBadge" Property="Background" Value="#107C10"/> <!-- Windows Green -->
                        </DataTrigger>
                        <DataTrigger Binding="{Binding MonitorIndex}" Value="3">
                            <Setter TargetName="MonitorBadge" Property="Background" Value="#D83B01"/> <!-- Windows Orange/Red -->
                        </DataTrigger>
                        <DataTrigger Binding="{Binding MonitorIndex}" Value="4">
                            <Setter TargetName="MonitorBadge" Property="Background" Value="#5C2D91"/> <!-- Windows Purple -->
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="5"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                            <Setter Property="IsEnabled" Value="False"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>
        </DockPanel>
    </Grid>
</Window>
