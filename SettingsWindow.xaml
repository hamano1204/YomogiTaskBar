<Window x:Class="YomogiTaskBar.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定" Width="480" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Topmost="True">
    <Window.Resources>
        <FontFamily x:Key="IconFont">Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol</FontFamily>
        
        <DropShadowEffect x:Key="WindowShadow" BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="2" Opacity="0.15"/>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" 
                                          BorderBrush="{TemplateBinding BorderBrush}" 
                                          BorderThickness="{TemplateBinding BorderThickness}" 
                                          Background="{TemplateBinding Background}" 
                                          ClickMode="Press" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition />
                                                    <ColumnDefinition Width="30" />
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0" Margin="10,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                                <TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Text="&#xE70D;" FontFamily="{StaticResource IconFont}" FontSize="10" Foreground="{DynamicResource PrimaryTextBrush}" />
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False"  Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="10,0,30,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="{DynamicResource WindowBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Margin="0,4,0,0"/>
                                    <ScrollViewer Margin="4,8,4,8" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Button Style with Fade Animation -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6"/>
                            <Border x:Name="HoverOverlay" Background="White" Opacity="0" CornerRadius="6"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverOverlay" Storyboard.TargetProperty="Opacity" To="0.1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverOverlay" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HoverOverlay" Property="Opacity" Value="0.2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Border Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="15">
        <Border.Effect>
            <StaticResource ResourceKey="WindowShadow"/>
        </Border.Effect>
        <DockPanel LastChildFill="True">
            <!-- Header -->
            <Border DockPanel.Dock="Top" Background="{DynamicResource HeaderBackgroundBrush}" Padding="20,12" CornerRadius="12,12,0,0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <TextBlock Text="設定" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center" Focusable="False"
                            Click="Close_Click" Background="Transparent" BorderThickness="0" 
                            Foreground="{DynamicResource SecondaryTextBrush}" FontSize="16" Cursor="Hand" Width="28" Height="28">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#E81123"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Footer -->
            <Border DockPanel.Dock="Bottom" Background="{DynamicResource HeaderBackgroundBrush}" Padding="20,16" CornerRadius="0,0,12,12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="YomogiTaskBar" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text=" v0.1.3" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" VerticalAlignment="Bottom" Margin="5,0,0,1"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="キャンセル" Click="Close_Click" Style="{StaticResource ModernButton}" Width="90" Height="32" Background="Transparent" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,10,0" Cursor="Hand"/>
                        <Button Content="保存" Click="Save_Click" Style="{StaticResource ModernButton}" Width="90" Height="32" Background="#007ACC" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content -->
            <Border Padding="24,20">
                <StackPanel>
                    <!-- Appearance Section -->
                    <TextBlock Text="外観" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8"/>
                    <Border Background="{DynamicResource HeaderBackgroundBrush}" CornerRadius="8" Padding="16,12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="テーマ設定" FontSize="12" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8"/>
                            <ComboBox x:Name="ThemeComboBox" Style="{StaticResource ModernComboBox}" SelectionChanged="ThemeComboBox_SelectionChanged" Margin="0,0,0,16">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                        <Setter Property="Padding" Value="10,6"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                                <ComboBoxItem Content="システム設定に従う" Tag="System"/>
                                <ComboBoxItem Content="ライトモード" Tag="Light"/>
                                <ComboBoxItem Content="ダークモード" Tag="Dark"/>
                            </ComboBox>
                            <TextBlock Text="アプリ一覧レイアウト" FontSize="12" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8"/>
                            <ComboBox x:Name="LayoutModeComboBox" Style="{StaticResource ModernComboBox}" SelectionChanged="LayoutModeComboBox_SelectionChanged">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                        <Setter Property="Padding" Value="10,6"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                                <ComboBoxItem Content="シンプルレイアウト（現在のデスクトップのみ）" Tag="Simple"/>
                                <ComboBoxItem Content="デスクトップをすべて表示" Tag="AllDesktops"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- Startup Section -->
                    <TextBlock Text="起動設定" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8"/>
                    <Border Background="{DynamicResource HeaderBackgroundBrush}" CornerRadius="8" Padding="16,12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,20">
                        <CheckBox x:Name="LaunchOnStartupCheckBox"
                                  Content="Windows起動時に自動で開始する"
                                  Foreground="{DynamicResource PrimaryTextBrush}"
                                  Checked="LaunchOnStartupCheckBox_Changed"
                                  Unchecked="LaunchOnStartupCheckBox_Changed"/>
                    </Border>

                    <!-- Global Shortcuts Section -->
                    <TextBlock Text="グローバルショートカット" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8"/>
                    <Border Background="{DynamicResource HeaderBackgroundBrush}" CornerRadius="8" Padding="16,12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="アプリをアクティブにする" FontSize="12" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8"/>
                            <Button x:Name="BtnGlobalActivate" Click="HotkeyButton_Click" Tag="GlobalActivate" 
                                    Content="Win + Esc" Padding="12,8" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Foreground="{DynamicResource PrimaryTextBrush}" HorizontalContentAlignment="Left" Cursor="Hand"
                                    AutomationProperties.Name="グローバルアクティベートショートカット" AutomationProperties.HelpText="設定ボタンを押した後、登録したいキーを同時に押してください">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding IsRecording, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                            <Setter TargetName="Border" Property="Background" Value="#1A007ACC"/>
                                                            <Setter TargetName="Border" Property="BorderBrush" Value="#007ACC"/>
                                                        </DataTrigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource ItemHoverBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- App Operation Shortcuts Section -->
                    <TextBlock Text="アプリ操作ショートカット" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8"/>
                    <Border Background="{DynamicResource HeaderBackgroundBrush}" CornerRadius="8" Padding="16,12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="最小化" FontSize="11" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"/>
                                    <Button x:Name="BtnMinimize" Click="HotkeyButton_Click" Tag="Minimize" Style="{StaticResource ModernButton}"
                                            Content="Ctrl + J" Padding="10,6" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Foreground="{DynamicResource PrimaryTextBrush}" HorizontalContentAlignment="Left" Cursor="Hand"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="最大化解除" FontSize="11" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"/>
                                    <Button x:Name="BtnToggleMaximize" Click="HotkeyButton_Click" Tag="ToggleMaximize" Style="{StaticResource ModernButton}"
                                            Content="Ctrl + K" Padding="10,6" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Foreground="{DynamicResource PrimaryTextBrush}" HorizontalContentAlignment="Left" Cursor="Hand"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="アプリを終了" FontSize="11" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"/>
                                    <Button x:Name="BtnClose" Click="HotkeyButton_Click" Tag="Close" Style="{StaticResource ModernButton}"
                                            Content="Ctrl + L" Padding="10,6" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Foreground="{DynamicResource PrimaryTextBrush}" HorizontalContentAlignment="Left" Cursor="Hand"/>
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="前のモニターへ移動" FontSize="11" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"/>
                                    <Button x:Name="BtnPrevMonitor" Click="HotkeyButton_Click" Tag="PrevMonitor" Style="{StaticResource ModernButton}"
                                            Content="Ctrl + U" Padding="10,6" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Foreground="{DynamicResource PrimaryTextBrush}" HorizontalContentAlignment="Left" Cursor="Hand"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="次のモニターへ移動" FontSize="11" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"/>
                                    <Button x:Name="BtnNextMonitor" Click="HotkeyButton_Click" Tag="NextMonitor" Style="{StaticResource ModernButton}"
                                            Content="Ctrl + I" Padding="10,6" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Foreground="{DynamicResource PrimaryTextBrush}" HorizontalContentAlignment="Left" Cursor="Hand"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                    <TextBlock Text="※ 設定ボタンを押した後、登録したいキーを同時に押してください。" 
                               FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </DockPanel>
    </Border>
</Window>
